# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moneylens

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGINS=*

# Better Auth (generate a random 32+ char secret)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Email (deferred — uncomment when needed)
# RESEND_API_KEY=
# RESEND_FROM=noreply@yourdomain.com

# AWS S3 (deferred — uncomment when needed)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_RECEIPT_BUCKET=moneylens-receipts

# ---------------------------------------------------------------------------
# Test environment (copy to apps/api/.env.test for running tests)
# Create a separate DB for tests: createdb moneylens_test
# Run schema push: bun --cwd apps/api run db:push:test
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moneylens_test
# BETTER_AUTH_URL=http://localhost:3000
# BETTER_AUTH_SECRET=test-secret-at-least-32-characters-long
