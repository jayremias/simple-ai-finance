{
	"name": "@moneylens/api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun dist/index.js",
		"lint": "biome check src/",
		"test": "NODE_ENV=test bun test",
		"db:push": "drizzle-kit push",
		"db:push:test": "DATABASE_URL=$TEST_DATABASE_URL drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@moneylens/shared": "workspace:*",
		"better-auth": "^1.5.0",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.38.0",
		"hono": "^4.7.0",
		"hono-rate-limiter": "^0.5.3",
		"postgres": "^3.4.0",
		"resend": "^6.9.3",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"drizzle-kit": "^0.30.0"
	}
}
