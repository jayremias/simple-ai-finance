{
  "name": "moneylens",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun --filter '*' test",
    "mobile": "bun --cwd apps/mobile run start",
    "mobile:ios": "bun --cwd apps/mobile run ios",
    "mobile:android": "bun --cwd apps/mobile run android"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "lefthook": "^2.1.2",
    "turbo": "^2.5.4",
    "typescript": "~5.9.2"
  },
  "packageManager": "bun@1.3.1"
}
